DB_NAME=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=

# To get started configure your database URI, or if you're using SQLITE no configuration needed

# SQLALCHEMY_DATABASE_URI = "dialect+driver://{DB_USER}:{DB_PASSWORD}@{DB_HOST}:{DB_PORT}/{DB_NAME}"
SQLALCHEMY_DATABASE_URI = "sqlite:///db_name.db"

# Security
# REQUIRED: secret key used to sign login tokens. start.sh generates one
# automatically if this is empty. To create one manually:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Device Configuration
# Chimera device model: 'chimera' or 'chimera-max'
# chimera-max has pump enabled for recirculation and pump-based calibration
CHIMERA_DEVICE_MODEL=chimera-max
COMPANY_NAME=Anaero Technology
LOGO_FILENAME=